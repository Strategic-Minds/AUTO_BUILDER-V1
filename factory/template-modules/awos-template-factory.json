      "approval_gates": ["production deploy", "database migration", "billing setup"],
      "validation": ["build", "route smoke", "schema dry run", "auth gate check"],
      "evidence": ["preview URL", "test log", "schema receipt", "rollback plan"],
      "fallback": "Generate docs and local scaffold only."
    },
    {
