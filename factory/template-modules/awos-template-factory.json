      "validation": ["page render", "form POST", "lead row confirmation", "mobile screenshot"],
      "evidence": ["desktop screenshot", "mobile screenshot", "lead row", "route smoke"],
      "fallback": "Static landing-page draft and manual lead form handoff."
    },
    {
