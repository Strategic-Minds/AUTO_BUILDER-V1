{
  "registry_name": "AWOS Template Factory",
  "registry_version": "1.0.0",
  "created_at": "2026-06-05T05:00:00Z",
  "purpose": "Standardize repeatable AUTO BUILDER modules with source truth, schemas, validation, approval gates, fallback routes, and evidence receipts.",
  "governance": {
    "templates_do_not_authorize_live_mutation": true,
    "sandbox_first": true,
    "approval_required_for": [
      "production_deploy",
      "database_mutation",
      "billing_or_spend",
      "external_publishing",
      "mass_outreach",
      "shopify_mutation",
      "environment_variable_mutation",
      "irreversible_infrastructure_change"
    ]
  },
  "required_module_fields": [
    "id",
    "name",
    "purpose",
    "default_mode",
    "source_truth_required",
    "outputs",
    "schemas",
    "approval_gates",
    "validation",
    "evidence",
    "fallback"
  ],
  "modules": [
    {
