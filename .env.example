# Core bridge auth
BRIDGE_API_KEY=
ADMIN_API_TOKEN=
CRON_API_TOKEN=
CRON_SECRET=
APPROVAL_PHRASE=EXECUTE APPROVED CHANGE

# Canonical URLs
APP_BASE_URL=https://auto-builder-livid.vercel.app
NEXT_PUBLIC_FRONTEND_URL=https://auto-builder-livid.vercel.app

# Workspace defaults
DEFAULT_WORKSPACE_ID=jeremy-business
DEFAULT_AUTONOMY_MODE=safe_write

# Factory mode
FACTORY_MODE=sandbox_first
PASSIVE_RESEARCH_ENABLED=true
REVERSE_ENGINEERING_COVERAGE_TARGET=maximum_grounded_public_and_connected_source
AUTO_BUILDER_SANDBOX_ENABLED=false
AUTO_BUILDER_EXECUTION_WORKER_ENABLED=false
AUTO_BUILDER_WORKER_TOKEN=

# Provider secrets
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
GITHUB_TOKEN=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_WORKSPACE_ACCESS_TOKEN=
GOOGLE_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CHAT_WEBHOOK_URL=
GOOGLE_CHAT_SPACE_ID=
GOOGLE_CHAT_BOT_TOKEN=
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
GROQ_API_KEY=
SHOPIFY_SHOP=
SHOPIFY_ADMIN_TOKEN=
HEYGEN_API_KEY=
XYLA_API_KEY=
METRICOOL_API_URL=
METRICOOL_API_TOKEN=
OPUS_CREDS=
N8N_WEBHOOK_URL=
N8N_API_KEY=

# Browser runtime
# Optional local override. Vercel uses @sparticuz/chromium automatically.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
BROWSER_WORKER_TOKEN=

# Runtime notes
# Vercel injects deployment metadata like VERCEL_GIT_COMMIT_SHA,
# VERCEL_GIT_COMMIT_REF, VERCEL_ENV, VERCEL_URL, and VERCEL_OIDC_TOKEN automatically.
# In production on Vercel, Sandbox can authenticate with the injected OIDC token.
# Do not hardcode deployment metadata here.
