# Core bridge auth
BRIDGE_API_KEY=
ADMIN_API_TOKEN=
CRON_API_TOKEN=
CRON_SECRET=
APPROVAL_PHRASE=EXECUTE APPROVED CHANGE

# Canonical URLs
APP_BASE_URL=https://auto-builder-livid.vercel.app
NEXT_PUBLIC_FRONTEND_URL=https://auto-builder-livid.vercel.app

# Workspace defaults
DEFAULT_WORKSPACE_ID=jeremy-business
DEFAULT_AUTONOMY_MODE=safe_write

# Factory mode
FACTORY_MODE=sandbox_first
PASSIVE_RESEARCH_ENABLED=true
REVERSE_ENGINEERING_COVERAGE_TARGET=maximum_grounded_public_and_connected_source
AUTO_BUILDER_SANDBOX_ENABLED=false

# Provider secrets
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
GITHUB_TOKEN=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
OPENAI_API_KEY=
GROQ_API_KEY=
SHOPIFY_SHOP=
SHOPIFY_ADMIN_TOKEN=
XYLA_API_KEY=
OPUS_CREDS=
SLACK_BOT_TOKEN=

# Runtime notes
# Vercel injects deployment metadata like VERCEL_GIT_COMMIT_SHA,
# VERCEL_GIT_COMMIT_REF, VERCEL_ENV, VERCEL_URL, and VERCEL_OIDC_TOKEN automatically.
# In production on Vercel, Sandbox can authenticate with the injected OIDC token.
# Do not hardcode deployment metadata here.
